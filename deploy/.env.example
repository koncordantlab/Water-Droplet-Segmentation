# Copy to deploy/.env and adjust for the box. deploy/.env is gitignored.

# Absolute path of the YOLO weights file on the host (mounted read-only).
WEIGHTS_FILE=/home/a/abadifard/PycharmProjects/NASA-Water-Droplet(LabRepo)/backend/app_root/weights_DP(8).pt

# Directory tree the API may read videos from (DROPLET_VIDEO_ROOTS) — mounted
# read-write at the identical path so outputs land next to inputs, like the
# venv deploy. The invoking user's home keeps today's default behavior.
VIDEO_ROOT=/home/a/abadifard

# Run the container as this uid:gid (id -u / id -g) so outputs are user-owned.
DEPLOY_UID=1000
DEPLOY_GID=1000

# Image tag to run: latest (default), sha-<short> for rollback, local for
# a locally built pre-merge image.
IMAGE_TAG=latest
